<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if pageTitle %}{{ pageTitle | escape }} | {% endif %}{{ site.name | escape }}</title>
{% if pageHead %}
  <meta name="description" content="{{ pageHead.description | escape }}">
{% if pageHead.canonical_url %}
  <link rel="canonical" href="{{ pageHead.canonical_url | escape }}">
{% endif %}
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.name | escape }}">
  <meta property="og:title" content="{{ pageHead.title | escape }}">
  <meta property="og:description" content="{{ pageHead.description | escape }}">
{% if pageHead.canonical_url %}
  <meta property="og:url" content="{{ pageHead.canonical_url | escape }}">
{% endif %}
{% if pageHead.image_url %}
  <meta property="og:image" content="{{ pageHead.image_url | escape }}">
  <meta property="og:image:alt" content="{{ pageHead.image_alt | escape }}">
{% endif %}
  <meta name="twitter:card" content="{{ pageHead.twitter_card | escape }}">
  <meta name="twitter:title" content="{{ pageHead.title | escape }}">
  <meta name="twitter:description" content="{{ pageHead.description | escape }}">
{% if pageHead.image_url %}
  <meta name="twitter:image" content="{{ pageHead.image_url | escape }}">
  <meta name="twitter:image:alt" content="{{ pageHead.image_alt | escape }}">
{% endif %}
{% if pageHead.structured_data %}
  <script type="application/ld+json">{{ pageHead.structured_data | jsonScript | safe }}</script>
{% endif %}
{% endif %}
  {% if site.has_custom_favicons %}
    {% for f in site.favicons %}
  <link rel="{{ f.rel }}" href="{{ f.href }}"{% if f.type %} type="{{ f.type }}"{% endif %}{% if f.sizes %} sizes="{{ f.sizes }}"{% endif %}>
    {% endfor %}
  {% else %}
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  {% endif %}
  <link id="site-theme" rel="stylesheet" href="/css/themes/{{ site.style | escape }}.css">
{% if site.theme_selector.enabled %}
  <script>
    (function () {
      var config = {{ site.theme_selector | jsonScript | safe }};
      var storageKey = "clodsite-theme";
      var queryTheme = new URLSearchParams(window.location.search).get("theme");
      var storedTheme = null;
      try { storedTheme = window.localStorage.getItem(storageKey); } catch (_) {}
      var theme = queryTheme !== null
        ? (config.options.includes(queryTheme) ? queryTheme : config.default)
        : (config.options.includes(storedTheme) ? storedTheme : config.default);
      document.getElementById("site-theme").href = "/css/themes/" + theme + ".css";
      window.__clodsiteTheme = { config: config, storageKey: storageKey, current: theme };
    }());
  </script>
{% endif %}
  <link rel="stylesheet" href="/css/components.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {% if site.style == "minimal" or (site.theme_selector.enabled and "minimal" in site.theme_selector.options) %}
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  {% endif %}
  {% if site.style == "professional" or (site.theme_selector.enabled and "professional" in site.theme_selector.options) %}
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  {% endif %}
  {% if site.style == "bold" or (site.theme_selector.enabled and "bold" in site.theme_selector.options) %}
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
  {% endif %}
</head>
<body class="theme-{{ site.style | escape }}">
{% if site.theme_selector.enabled %}
  <script>
    document.body.className = "theme-" + window.__clodsiteTheme.current;
  </script>
{% endif %}
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-name">{{ site.name | escape }}</a>
      <ul class="nav-links">
        {% for navPage in site.nav.pages %}
          <li><a href="{{ navPage.href | escape }}">{{ navPage.title | escape }}</a></li>
        {% endfor %}
      </ul>
{% if site.theme_selector.enabled %}
      <label class="theme-selector" hidden>
        <span>Theme</span>
        <select aria-label="Theme">
{% for theme in site.theme_selector.options %}          <option value="{{ theme | escape }}">{{ theme | capitalize | escape }}</option>
{% endfor %}        </select>
      </label>
{% endif %}
    </nav>
  </header>
  <main class="site-main">
    {{ content | safe }}
  </main>
  <footer class="site-footer">
    <p>
      &copy; {{ site.name | escape }}
      {% if site.contact.enabled %}
        &nbsp;·&nbsp; <a href="mailto:{{ site.contact.email | escape }}">{{ site.contact.email | escape }}</a>
      {% endif %}
    </p>
  </footer>
{% if site.theme_selector.enabled %}
  <script>
    (function () {
      var state = window.__clodsiteTheme;
      var wrapper = document.querySelector(".theme-selector");
      var select = wrapper.querySelector("select");

      function applyTheme(theme, updateUrl) {
        if (!state.config.options.includes(theme)) return;
        document.getElementById("site-theme").href = "/css/themes/" + theme + ".css";
        document.body.className = "theme-" + theme;
        select.value = theme;
        state.current = theme;
        try { window.localStorage.setItem(state.storageKey, theme); } catch (_) {}
        if (updateUrl) {
          try {
            var url = new URL(window.location.href);
            url.searchParams.set("theme", theme);
            window.history.replaceState({}, "", url);
          } catch (_) {}
        }
      }

      select.addEventListener("change", function () {
        applyTheme(select.value, true);
      });
      applyTheme(state.current, false);
      wrapper.hidden = false;
    }());
  </script>
{% endif %}
</body>
</html>
