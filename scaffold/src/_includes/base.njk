<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if pageTitle %}{{ pageTitle | escape }} | {% endif %}{{ site.name | escape }}</title>
{% if pageHead %}
  <meta name="description" content="{{ pageHead.description | escape }}">
{% if pageHead.canonical_url %}
  <link rel="canonical" href="{{ pageHead.canonical_url | escape }}">
{% endif %}
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.name | escape }}">
  <meta property="og:title" content="{{ pageHead.title | escape }}">
  <meta property="og:description" content="{{ pageHead.description | escape }}">
{% if pageHead.canonical_url %}
  <meta property="og:url" content="{{ pageHead.canonical_url | escape }}">
{% endif %}
{% if pageHead.image_url %}
  <meta property="og:image" content="{{ pageHead.image_url | escape }}">
  <meta property="og:image:alt" content="{{ pageHead.image_alt | escape }}">
{% endif %}
  <meta name="twitter:card" content="{{ pageHead.twitter_card | escape }}">
  <meta name="twitter:title" content="{{ pageHead.title | escape }}">
  <meta name="twitter:description" content="{{ pageHead.description | escape }}">
{% if pageHead.image_url %}
  <meta name="twitter:image" content="{{ pageHead.image_url | escape }}">
  <meta name="twitter:image:alt" content="{{ pageHead.image_alt | escape }}">
{% endif %}
{% if pageHead.structured_data %}
  <script type="application/ld+json">{{ pageHead.structured_data | jsonScript | safe }}</script>
{% endif %}
{% endif %}
  {% if site.has_custom_favicons %}
    {% for f in site.favicons %}
  <link rel="{{ f.rel }}" href="{{ f.href }}"{% if f.type %} type="{{ f.type }}"{% endif %}{% if f.sizes %} sizes="{{ f.sizes }}"{% endif %}>
    {% endfor %}
  {% else %}
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  {% endif %}
  <link id="site-theme" rel="stylesheet" href="/css/themes/{{ site.style | escape }}.css">
{% if site.theme_selector.enabled %}
  <script>
    (function () {
      var config = {{ site.theme_selector | jsonScript | safe }};
      var storageKey = "clodsite-theme";
      var queryTheme = new URLSearchParams(window.location.search).get("theme");
      var storedTheme = null;
      try { storedTheme = window.localStorage.getItem(storageKey); } catch (_) {}
      var theme = queryTheme !== null
        ? (config.options.includes(queryTheme) ? queryTheme : config.default)
        : (config.options.includes(storedTheme) ? storedTheme : config.default);
      document.getElementById("site-theme").href = "/css/themes/" + theme + ".css";
      window.__clodsiteTheme = { config: config, storageKey: storageKey, current: theme };
    }());
  </script>
{% endif %}
  <link rel="stylesheet" href="/css/components.css">
{% if site.commerce.cart_enabled %}
  <link rel="stylesheet" href="/css/cart.css">
{% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {% if site.style == "minimal" or (site.theme_selector.enabled and "minimal" in site.theme_selector.options) %}
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  {% endif %}
  {% if site.style == "professional" or (site.theme_selector.enabled and "professional" in site.theme_selector.options) %}
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  {% endif %}
  {% if site.style == "bold" or (site.theme_selector.enabled and "bold" in site.theme_selector.options) %}
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
  {% endif %}
</head>
<body class="theme-{{ site.style | escape }}">
{% if site.theme_selector.enabled %}
  <script>
    document.body.className = "theme-" + window.__clodsiteTheme.current;
  </script>
{% endif %}
  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="site-name">{{ site.name | escape }}</a>
      <ul class="nav-links">
        {% for navPage in site.nav.pages %}
          <li><a href="{{ navPage.href | escape }}">{{ navPage.title | escape }}</a></li>
        {% endfor %}
      </ul>
{% if site.theme_selector.enabled %}
      <label class="theme-selector" hidden>
        <span>Theme</span>
        <select aria-label="Theme">
{% for theme in site.theme_selector.options %}          <option value="{{ theme | escape }}">{{ theme | capitalize | escape }}</option>
{% endfor %}        </select>
      </label>
{% endif %}
{% if site.commerce.cart_enabled %}
      <button class="cart-toggle" type="button" aria-expanded="false" aria-controls="cart-drawer" hidden>
        Cart<span class="cart-toggle__count" aria-label="items in cart" hidden>0</span>
      </button>
{% endif %}
    </nav>
  </header>
  <main class="site-main">
    {{ content | safe }}
  </main>
  <footer class="site-footer">
    <p>
      &copy; {{ site.name | escape }}
      {% if site.contact.enabled %}
        &nbsp;·&nbsp; <a href="mailto:{{ site.contact.email | escape }}">{{ site.contact.email | escape }}</a>
      {% endif %}
    </p>
  </footer>
{% if site.theme_selector.enabled %}
  <script>
    (function () {
      var state = window.__clodsiteTheme;
      var wrapper = document.querySelector(".theme-selector");
      var select = wrapper.querySelector("select");

      function applyTheme(theme, updateUrl) {
        if (!state.config.options.includes(theme)) return;
        document.getElementById("site-theme").href = "/css/themes/" + theme + ".css";
        document.body.className = "theme-" + theme;
        select.value = theme;
        state.current = theme;
        try { window.localStorage.setItem(state.storageKey, theme); } catch (_) {}
        if (updateUrl) {
          try {
            var url = new URL(window.location.href);
            url.searchParams.set("theme", theme);
            window.history.replaceState({}, "", url);
          } catch (_) {}
        }
      }

      select.addEventListener("change", function () {
        applyTheme(select.value, true);
      });
      applyTheme(state.current, false);
      wrapper.hidden = false;
    }());
  </script>
{% endif %}
{% if site.commerce.cart_enabled %}
  <div class="cart-drawer" id="cart-drawer" hidden>
    <div class="cart-drawer__backdrop"></div>
    <aside class="cart-drawer__panel" role="dialog" aria-modal="true" aria-label="Shopping cart">
      <header class="cart-drawer__header">
        <h2 class="cart-drawer__title">Cart</h2>
        <button class="cart-drawer__close" type="button" aria-label="Close cart">&times;</button>
      </header>
      <p class="cart-drawer__empty">Your cart is empty.</p>
      <ul class="cart-drawer__items"></ul>
      <footer class="cart-drawer__footer">
        <p class="cart-drawer__total"><span>Total</span><span class="cart-drawer__total-amount"></span></p>
        <button class="cart-drawer__checkout" type="button">Checkout</button>
        <p class="cart-drawer__error" role="alert" hidden>Checkout failed — please try again.</p>
{% if site.commerce.preview %}
        <p class="cart-drawer__note">Checkout is coming soon.</p>
{% endif %}
      </footer>
    </aside>
  </div>
  <script>
    (function () {
      var config = {{ site.commerce | jsonScript | safe }};
      var storageKey = "clodsite_cart";
      var catalogSet = new Set(config.catalog_set);
      // Display-only formatting of cached minor units (spec §5); checkout
      // re-prices server-side from the committed catalog.
      var EXPONENTS = { jpy: 0, krw: 0 };
      var SYMBOLS = { usd: "$", cad: "$", aud: "$", eur: "€", gbp: "£" };

      function formatMinor(minor) {
        var code = config.currency;
        var exponent = code in EXPONENTS ? EXPONENTS[code] : 2;
        var amount = (minor / Math.pow(10, exponent)).toFixed(exponent);
        var symbol = SYMBOLS[code];
        return symbol ? symbol + amount : amount + " " + code.toUpperCase();
      }

      // Item identity is the (slug, optionValues) tuple, keyed in declared
      // option order — the same order the catalog component collects them in.
      function itemKey(slug, optionValues) {
        return [slug].concat(Object.values(optionValues || {})).join(":");
      }

      function load() {
        var stored = [];
        try { stored = JSON.parse(window.localStorage.getItem(storageKey)) || []; } catch (_) {}
        if (!Array.isArray(stored)) stored = [];
        // Purge items the deployed catalog no longer sells (spec §5).
        return stored.filter(function (item) {
          return item && typeof item.slug === "string" && typeof item.name === "string" &&
            Number.isInteger(item.price_minor) && item.price_minor >= 0 &&
            Number.isInteger(item.qty) && item.qty > 0 &&
            catalogSet.has(itemKey(item.slug, item.optionValues));
        });
      }

      function save() {
        try { window.localStorage.setItem(storageKey, JSON.stringify(items)); } catch (_) {}
      }

      var items = load();
      save();

      var toggle = document.querySelector(".cart-toggle");
      var count = toggle.querySelector(".cart-toggle__count");
      var drawer = document.getElementById("cart-drawer");
      var list = drawer.querySelector(".cart-drawer__items");
      var emptyNote = drawer.querySelector(".cart-drawer__empty");
      var totalAmount = drawer.querySelector(".cart-drawer__total-amount");
      var checkout = drawer.querySelector(".cart-drawer__checkout");
      var checkoutError = drawer.querySelector(".cart-drawer__error");

      function changeQty(index, delta) {
        items[index].qty += delta;
        if (items[index].qty <= 0) items.splice(index, 1);
        save();
        render();
      }

      function controlButton(label, ariaLabel, onClick) {
        var button = document.createElement("button");
        button.type = "button";
        button.className = "cart-drawer__qty-button";
        button.textContent = label;
        button.setAttribute("aria-label", ariaLabel);
        button.addEventListener("click", onClick);
        return button;
      }

      function renderItem(item, index) {
        var li = document.createElement("li");
        li.className = "cart-drawer__item";
        if (item.image) {
          var img = document.createElement("img");
          img.className = "cart-drawer__item-image";
          img.src = item.image;
          img.alt = "";
          li.appendChild(img);
        }
        var body = document.createElement("div");
        body.className = "cart-drawer__item-body";
        var name = document.createElement("p");
        name.className = "cart-drawer__item-name";
        name.textContent = item.name;
        body.appendChild(name);
        var optionText = Object.values(item.optionValues || {}).join(" / ");
        if (optionText) {
          var options = document.createElement("p");
          options.className = "cart-drawer__item-options";
          options.textContent = optionText;
          body.appendChild(options);
        }
        var controls = document.createElement("div");
        controls.className = "cart-drawer__item-controls";
        controls.appendChild(controlButton("−", "Decrease quantity of " + item.name, function () { changeQty(index, -1); }));
        var qty = document.createElement("span");
        qty.className = "cart-drawer__qty";
        qty.textContent = String(item.qty);
        controls.appendChild(qty);
        controls.appendChild(controlButton("+", "Increase quantity of " + item.name, function () { changeQty(index, 1); }));
        var remove = document.createElement("button");
        remove.type = "button";
        remove.className = "cart-drawer__remove";
        remove.textContent = "Remove";
        remove.setAttribute("aria-label", "Remove " + item.name + " from cart");
        remove.addEventListener("click", function () { items.splice(index, 1); save(); render(); });
        controls.appendChild(remove);
        body.appendChild(controls);
        li.appendChild(body);
        var price = document.createElement("p");
        price.className = "cart-drawer__item-price";
        price.textContent = formatMinor(item.price_minor * item.qty);
        li.appendChild(price);
        return li;
      }

      function render() {
        var totalQty = 0;
        var totalMinor = 0;
        list.textContent = "";
        items.forEach(function (item, index) {
          totalQty += item.qty;
          totalMinor += item.price_minor * item.qty;
          list.appendChild(renderItem(item, index));
        });
        count.textContent = String(totalQty);
        count.hidden = totalQty === 0;
        emptyNote.hidden = items.length > 0;
        totalAmount.textContent = formatMinor(totalMinor);
        // Preview ships the cart chrome without live checkout (spec §2).
        checkout.disabled = config.preview || items.length === 0;
      }

      function openDrawer() {
        drawer.hidden = false;
        toggle.setAttribute("aria-expanded", "true");
      }

      function closeDrawer() {
        drawer.hidden = true;
        toggle.setAttribute("aria-expanded", "false");
      }

      toggle.addEventListener("click", function () {
        if (drawer.hidden) openDrawer(); else closeDrawer();
      });
      if (!config.preview) {
        checkout.addEventListener("click", function () {
          if (items.length === 0) return;
          checkout.disabled = true;
          checkoutError.hidden = true;
          // The server re-resolves prices and refs from the committed catalog;
          // the client sends only what it chose (spec §6).
          fetch("/api/checkout", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              items: items.map(function (item) {
                return { slug: item.slug, optionValues: item.optionValues || {}, qty: item.qty };
              })
            })
          }).then(function (response) {
            if (!response.ok) throw new Error("checkout " + response.status);
            return response.json();
          }).then(function (data) {
            window.location.assign(data.url);
          }).catch(function () {
            checkout.disabled = items.length === 0;
            checkoutError.hidden = false;
          });
        });
      }
      drawer.querySelector(".cart-drawer__close").addEventListener("click", closeDrawer);
      drawer.querySelector(".cart-drawer__backdrop").addEventListener("click", closeDrawer);
      document.addEventListener("keydown", function (event) {
        if (event.key === "Escape" && !drawer.hidden) closeDrawer();
      });

      // The catalog component asks before dispatching so it can flash
      // "Unavailable" on combinations the deployed catalog doesn't sell.
      window.__clodsiteCart = {
        sells: function (slug, optionValues) {
          return catalogSet.has(itemKey(slug, optionValues));
        }
      };

      document.addEventListener("clodsite:cart:add", function (event) {
        var detail = event.detail || {};
        var key = itemKey(detail.slug, detail.optionValues);
        if (!catalogSet.has(key)) return;
        var existing = null;
        for (var i = 0; i < items.length; i++) {
          if (itemKey(items[i].slug, items[i].optionValues) === key) { existing = items[i]; break; }
        }
        if (existing) {
          existing.qty += 1;
        } else {
          items.push({
            slug: detail.slug,
            name: detail.name,
            price_minor: detail.price_minor,
            image: detail.image,
            optionValues: detail.optionValues || {},
            qty: 1
          });
        }
        save();
        render();
        openDrawer();
      });

      render();
      toggle.hidden = false;
    }());
  </script>
{% endif %}
</body>
</html>
